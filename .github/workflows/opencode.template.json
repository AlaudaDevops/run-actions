{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "openai/gpt-5.3-codex",
  "model": "openai/gpt-5.4",
  "provider": {
    "openai": {
      "name": "OpenAI",
      "npm": "@ai-sdk/openai",
      "options": {
        "baseURL": "{env:OPENAI_BASEURL}",
        "apiKey": "{env:OPENAI_TOKEN}"
      },
      "models": {
        "gpt-5.4": {
          "limit": {
            "context": 258000,
            "output": 128000
          }
        },
        "gpt-5.3-codex": {
          "limit": {
            "context": 258000,
            "output": 128000
          }
        }
      }
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  }
}
