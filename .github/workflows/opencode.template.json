{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "codex/gpt-5.3-codex",
  "model": "codex/gpt-5.4",
  "provider": {
    "codex": {
      "name": "Codex",
      "npm": "@ai-sdk/openai",
      "options": {
        "baseURL": "{env:OPENAI_BASEURL}",
        "apiKey": "{env:OPENAI_TOKEN}"
      },
      "models": {
        "gpt-5.4": {
          "limit": {
            "context": 258000,
            "output": 128000
          }
        },
        "gpt-5.3-codex": {
          "limit": {
            "context": 258000,
            "output": 128000
          }
        }
      }
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "task": "allow",
    "external_directory": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "lsp": "allow",
    "doom_loop": "allow",
    "write": "allow",
    "skill": "allow"
  }
}
